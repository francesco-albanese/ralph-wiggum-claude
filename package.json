{
  "name": "@franco-albanese/ralph",
  "version": "0.0.0",
  "private": true,
  "description": "Ralph: TypeScript CLI that runs AI coding agents in a loop and ships PRs",
  "type": "module",
  "bin": {
    "ralph": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.4"
  }
}
